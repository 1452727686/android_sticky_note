<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/widget_bg_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/sticky_note_widget_bg_light" />

    <LinearLayout
        android:id="@+id/widget_content_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp">

        <RelativeLayout
            android:id="@+id/widget_header_row"
            android:layout_width="match_parent"
            android:layout_height="24dp">

            <TextView
                android:id="@+id/widget_add_button"
                android:layout_width="28dp"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:gravity="center"
                android:paddingBottom="4dp"
                android:text="+"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/widget_right_group"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_last_sync_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="3dp"
                    android:paddingTop="2dp"
                    android:text="Last update --:--:--"
                    android:textSize="12sp"
                    android:textStyle="normal" />

                <TextView
                    android:id="@+id/widget_refresh_button"
                    android:layout_width="28dp"
                    android:layout_height="24dp"
                    android:gravity="center"
                    android:paddingBottom="4dp"
                    android:text="&#x21BB;"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <FrameLayout
            android:id="@+id/widget_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="1dp" />

        <FrameLayout
            android:id="@+id/widget_list_host"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/widget_todo_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:cacheColorHint="@android:color/transparent"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:fadeScrollbars="true"
                android:fadingEdgeLength="12dp"
                android:scrollbarStyle="outsideInset"
                android:scrollbars="vertical" />

            <TextView
                android:id="@+id/widget_empty_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical|start"
                android:paddingStart="2dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="No todos"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>

</FrameLayout>
